# Calendar Sync Agent — configuration
# Copy this file to .env and fill in the required values.
# Lines starting with # are comments and ignored.

# ──────────────────────────────────────────────
# REQUIRED
# ──────────────────────────────────────────────

# Corporate calendar iCal URL (secret — treat like a password)
# Find at: Google Calendar → Settings → your corporate calendar
#   → "Integrate calendar" → "Secret address in iCal format"
ICAL_URL=

# ──────────────────────────────────────────────
# OPTIONAL (defaults shown)
# ──────────────────────────────────────────────

# Personal calendar to sync blocks into.
# "primary" = default calendar. Or use a specific calendar ID
# (Google Calendar → Settings → calendar → Integrate → Calendar ID)
# PERSONAL_CALENDAR_ID=primary

# How many days ahead to sync
# SYNC_DAYS=14

# Title for anonymized blocks
# BLOCK_TITLE=Meeting

# Event colour ID. Maps to your Google Calendar colour labels.
# "1" lavender  "2" sage       "3" grape      "4" flamingo
# "5" banana    "6" tangerine  "7" peacock    "8" graphite
# "9" blueberry "10" basil     "11" tomato
# Set to empty to inherit the target calendar's default colour.
# BLOCK_COLOUR=3

# "opaque" = shows as busy, "transparent" = shows as free
# BLOCK_STATUS=opaque

# ──────────────────────────────────────────────
# PATHS (override if credentials live elsewhere)
# ──────────────────────────────────────────────

# Path to Google OAuth client-secrets JSON
# GOOGLE_CREDENTIALS_FILE=./credentials.json

# Path to saved OAuth token (auto-created on first run)
# GOOGLE_TOKEN_FILE=./token.json
